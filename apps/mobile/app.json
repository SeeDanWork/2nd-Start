{
  "expo": {
    "name": "Anti-Drama Co-Parenting",
    "slug": "adcp",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "adcp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adcp.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.adcp.app"
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
