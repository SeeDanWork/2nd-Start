{
  "name": "@adcp/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "migration:generate": "typeorm migration:generate",
    "migration:run": "typeorm migration:run -d dist/data-source.js",
    "migration:revert": "typeorm migration:revert -d dist/data-source.js",
    "seed": "ts-node src/seeds/run.ts"
  },
  "dependencies": {
    "@adcp/shared": "*",
    "@anthropic-ai/sdk": "^0.78.0",
    "@nestjs/axios": "^3.1.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^11.1.13",
    "axios": "^1.7.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.6.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.9.2",
    "rxjs": "^7.8.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^9.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
